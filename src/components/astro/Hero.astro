---
import { siteData } from '../../data/siteData';
import { toDomId } from '../../utils/domId';
import Icon from './Icon.astro';

const { hero } = siteData;
---

<div id="hero" class="relative bg-gray-900 h-screen min-h-[800px] flex flex-col justify-between font-sans overflow-hidden">
  <div id="hero-background" class="absolute inset-0 overflow-hidden">
    <img
      id="hero-background-image"
      src={hero.backgroundImage}
      alt="Textile Factory"
      class="hero-bg-zoom w-full h-full object-cover opacity-50 blur-[1px]"
    />
    <div id="hero-background-overlay" class="absolute inset-0 bg-gradient-to-t from-gray-900 via-gray-900/40 to-transparent"></div>
  </div>

  <div id="hero-content" class="relative w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-40 flex-grow flex flex-col justify-center">
    <div id="hero-content-inner" class="hero-copy max-w-5xl text-left">
      <div id="hero-accent-bar" class="hero-accent inline-block h-1 bg-blue-500 mb-6"></div>
      <h1 id="hero-heading" class="text-2xl md:text-4xl lg:text-5xl font-bold text-white tracking-tight mb-6 leading-tight">
        {hero.heading.title}<br />
        <span id="hero-heading-accent" class="text-blue-400 text-xl md:text-[2rem]">{hero.heading.accent}</span>
      </h1>
      <p id="hero-subtitle" class="mt-4 text-base md:text-lg text-gray-200 mb-10 max-w-2xl leading-relaxed">
        {hero.subtitle}
      </p>
    </div>
  </div>

  <div id="hero-features" class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-8 md:pb-12 w-full">
    <div id="hero-features-grid" class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-5 gap-x-4 gap-y-6 md:gap-6 border-t border-gray-700 pt-6 md:pt-8">
      {hero.features.map((feature, index) => {
        const featureId = toDomId('hero-feature', index + 1, feature.title);
        return (
          <div
            id={featureId}
            class={`hero-feature group cursor-pointer ${index === 4 ? 'col-span-2 sm:col-span-1 lg:col-span-1' : ''}`}
            style={`--feature-delay: ${800 + index * 100}ms`}
          >
            <div id={`${featureId}-header`} class="flex items-center mb-2 md:mb-3">
              <Icon name={feature.icon} id={`${featureId}-icon`} class="w-5 h-5 text-blue-400 mr-2 group-hover:scale-110 transition-transform duration-300 flex-shrink-0" />
              <h3 id={`${featureId}-title`} class="text-[15px] md:text-lg font-bold text-white group-hover:text-blue-400 transition-colors leading-tight">
                {feature.title}
              </h3>
            </div>
            <p id={`${featureId}-description`} class="text-[12px] md:text-sm text-gray-400 leading-relaxed group-hover:text-gray-300 transition-colors">
              {feature.descriptionLines.map((line) => <span class="block">{line}</span>)}
            </p>
          </div>
        );
      })}
    </div>
    <div id="hero-endorsement" class="mt-8 md:mt-6 text-center text-xs md:text-sm text-gray-400">
      {hero.endorsement}
    </div>
  </div>
</div>
