---
import type { ApronCatalogItem } from '../../data/siteData';
import { toDomId } from '../../utils/domId';

type ProductGalleryPageData = {
  eyebrow: string;
  title: string;
  description: string;
  stats: ReadonlyArray<{ label: string; value: string }>;
  items: ReadonlyArray<ApronCatalogItem>;
  galleryLabel: string;
};

type Props = {
  pageId: string;
  pageData: ProductGalleryPageData;
};

const { pageId, pageData } = Astro.props;
const productDetailLinks = [
  { pageId: 'chef-wear-page', label: 'Chef Wear', path: '/products/chef-wear' },
  { pageId: 'casuals-page', label: 'Casuals', path: '/products/casuals' },
  { pageId: 'aprons-page', label: 'Aprons', path: '/products/aprons' },
];
const currentProductLink = productDetailLinks.find((link) => link.pageId === pageId) ?? productDetailLinks[0];
---

<div id={pageId} class="bg-stone-50 text-slate-900">
  <section class="relative overflow-hidden bg-slate-950 pb-16 pt-36 text-white md:pb-20 md:pt-44">
    <div class="absolute inset-0">
      <div class="absolute -left-24 top-10 h-80 w-80 rounded-full bg-blue-500/20 blur-3xl"></div>
      <div class="absolute right-0 top-0 h-96 w-96 rounded-full bg-cyan-400/10 blur-3xl"></div>
      <div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>
    </div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div id={`${pageId}-hero-copy`} class="reveal max-w-5xl">
        <nav aria-label="Breadcrumb" class="mb-8 text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">
          <ol class="flex flex-wrap items-center gap-2">
            <li>
              <a href="/" class="clickable-cursor transition-colors hover:text-white">Home</a>
            </li>
            <li aria-hidden="true" class="text-slate-600">/</li>
            <li>
              <a href="/#products" class="clickable-cursor transition-colors hover:text-white">Products</a>
            </li>
            <li aria-hidden="true" class="text-slate-600">/</li>
            <li aria-current="page" class="text-blue-300">{currentProductLink.label}</li>
          </ol>
        </nav>

        <div class="max-w-4xl">
          <p class="mb-4 text-xs font-semibold uppercase tracking-[0.32em] text-blue-300">{pageData.eyebrow}</p>
          <h1 class="text-4xl font-bold leading-[1.05] tracking-tight md:text-6xl">{pageData.title}</h1>
          <p class="mt-6 max-w-2xl text-sm leading-7 text-slate-300 md:text-base">{pageData.description}</p>
        </div>

        <div class="mt-10 flex flex-wrap gap-3">
          {pageData.stats.map((stat, index) => (
            <div id={toDomId(pageId, 'stat', stat.label)} class="reveal" style={`--reveal-delay: ${120 + index * 80}ms`}>
              <div class="rounded-full border border-white/12 bg-white/5 px-4 py-2 backdrop-blur-sm">
                <div class="flex items-center gap-3">
                  <span class="text-lg font-bold tracking-tight text-white">{stat.value}</span>
                  <span class="text-[10px] uppercase tracking-[0.24em] text-slate-400">{stat.label}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="pb-24 pt-12 md:pt-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="reveal mb-10 flex flex-col gap-6 border-b border-stone-200 pb-10 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="mb-2 text-xs font-semibold uppercase tracking-[0.28em] text-blue-700">Product Gallery</p>
          <h2 class="text-2xl font-bold tracking-tight text-slate-900 md:text-4xl">
            {pageData.items.length} {pageData.galleryLabel}
          </h2>
        </div>
        <nav aria-label="Switch product detail page" class="flex flex-wrap gap-2">
          {productDetailLinks.map((link) => {
            const isActive = link.pageId === pageId;
            return (
              <a
                href={link.path}
                aria-current={isActive ? 'page' : undefined}
                class={`clickable-cursor cursor-pointer rounded-full border px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] transition-colors ${
                  isActive
                    ? 'border-slate-900 bg-slate-900 text-white'
                    : 'border-stone-300 bg-white text-slate-600 hover:border-blue-700 hover:text-blue-700'
                }`}
              >
                {link.label}
              </a>
            );
          })}
        </nav>
      </div>

      <div class="grid gap-8 md:grid-cols-2 xl:grid-cols-3">
        {pageData.items.map((item, index) => (
          <div
            id={toDomId(pageId, 'card-wrap', item.code, item.name)}
            class="reveal h-full"
            style={`--reveal-delay: ${(index % 6) * 20}ms`}
          >
            <article
              id={toDomId(pageId, 'card', item.code, item.name)}
              class="group overflow-hidden rounded-[28px] border border-stone-200 bg-white shadow-[0_24px_60px_-32px_rgba(15,23,42,0.28)] transition-transform duration-500 hover:-translate-y-1"
            >
              <div class="relative overflow-hidden bg-white p-6">
                <img
                  id={toDomId(pageId, 'image', item.code, item.name)}
                  src={item.image}
                  alt={item.name}
                  loading={index < 8 ? 'eager' : 'lazy'}
                  decoding="async"
                  class="h-[480px] w-full object-contain object-center"
                />
              </div>
            </article>
          </div>
        ))}
      </div>
    </div>
  </section>
</div>
