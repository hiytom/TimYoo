---
import { siteData } from '../../data/siteData';
import { toDomId } from '../../utils/domId';

const { productsSection } = siteData;
---

<section id="products" class="py-12 md:py-24 bg-white font-sans">
  <div id="products-container" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div id="products-header" class="reveal text-center mb-10 md:mb-16">
      <h2 id="products-title" class="text-3xl md:text-4xl font-bold text-gray-900 mb-4 tracking-tight">{productsSection.title}</h2>
      <p id="products-description" class="text-lg text-gray-600 max-w-2xl mx-auto">
        {productsSection.description}
      </p>
    </div>

    <div id="products-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
      {productsSection.items.map((product, index) => (
        <div id={toDomId('product-item', product.id, product.category)} class="reveal" style={`--reveal-delay: ${index * 100}ms`}>
          <a id={toDomId('product-link', product.id, product.category)} href={product.href} class="clickable-cursor block cursor-pointer">
            <div id={toDomId('product-card', product.id, product.category)} class="clickable-cursor group cursor-pointer transition-transform duration-300 hover:-translate-y-2.5">
              <div id={toDomId('product-image-wrap', product.id, product.category)} class="relative mb-6 aspect-[4/5] cursor-pointer overflow-hidden rounded-lg shadow-md">
                <img
                  id={toDomId('product-image', product.id, product.category)}
                  src={product.image}
                  alt={product.name}
                  class="h-full w-full cursor-pointer object-cover transition-transform duration-500 group-hover:scale-105"
                />
                <div id={toDomId('product-image-overlay', product.id, product.category)} class="absolute inset-0 cursor-pointer bg-black/20 transition-colors duration-300 group-hover:bg-black/10"></div>
                <div id={toDomId('product-category-badge', product.id, product.category)} class="absolute left-4 top-4 cursor-pointer rounded-full bg-white/90 px-3 py-1 text-xs font-bold uppercase tracking-wider text-gray-900 backdrop-blur-sm">
                  {product.category}
                </div>
                <div id={toDomId('product-cta', product.id, product.category)} class="absolute bottom-4 left-4 cursor-pointer rounded-full bg-white/90 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-900 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                  View collection
                </div>
              </div>
              <h3 id={toDomId('product-name', product.id, product.category)} class="mb-2 cursor-pointer text-xl font-bold text-gray-900 transition-colors group-hover:text-blue-600">
                {product.name}
              </h3>
              <p id={toDomId('product-description', product.id, product.category)} class="cursor-pointer leading-relaxed text-gray-600">
                {product.descriptionLines.map((line) => <span class="block">{line}</span>)}
              </p>
            </div>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
