---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/astro/Icon.astro';
import { siteData } from '../data/siteData';
import { absoluteUrl, buildOrganizationJsonLd } from '../utils/structuredData';
import { toDomId } from '../utils/domId';

const canonicalPath = '/southeast-asia-garment-factory/';
const pageTitle = 'Southeast Asia Garment Factory | Cambodia Apparel Manufacturer | TIMYOO Apparel';
const pageDescription =
  'Southeast Asia garment factory partner based in Cambodia, supporting global brands with repeat apparel production, stable capacity, quality control, and buyer-ready factory visibility.';
const ogImage = '/assets/about/facility/facility-09.jpg';

const proofPoints = [
  { value: '2', label: 'Cambodia factory sites' },
  { value: '400+', label: 'skilled local workers' },
  { value: '150,000+', label: 'monthly capacity' },
  { value: '12', label: 'program-based production lines' },
];

const factoryTimelineEvents = [
  {
    year: 'Before 2018',
    title: 'Manufacturing roots in China',
    description:
      'Our team built its early apparel manufacturing base through long-running production work before expanding deeper into Southeast Asia.',
  },
  {
    year: '2018-2024',
    title: 'First Cambodia factory established',
    description:
      'TIMYOO Apparel built stable Cambodia operations for repeat garment production, buyer communication, and factory-direct apparel sourcing.',
  },
  {
    year: '2025',
    title: 'Second Cambodia factory launched',
    description:
      'A second Cambodia site expanded our Southeast Asia garment factory capacity for workwear, aprons, chef wear, and casualwear programs.',
  },
];

const gallerySections = [
  {
    eyebrow: 'Factory Sites',
    title: 'Cambodia-based production inside Southeast Asia',
    summary:
      'Our factory sites in Cambodia give buyers a Southeast Asia garment production base with lower landed cost options, stable capacity, and direct factory communication.',
    images: [
      {
        src: '/assets/about/our-journey-timyoo-cambodia.jpg',
        alt: 'TIMYOO Apparel Cambodia garment factory exterior',
      },
      {
        src: '/assets/about/our-journey-young-me-apparel.jpg',
        alt: 'Young Me Apparel Cambodia factory entrance for garment production',
      },
    ],
  },
  {
    eyebrow: 'Production Teams',
    title: 'Workers supporting repeat garment programs',
    summary:
      'Production, sewing, quality control, packing, and support teams work through repeat programs for hospitality apparel, chef wear, aprons, and casualwear.',
    images: [
      {
        src: '/assets/about/factory-people/factory-people-01.jpg',
        alt: 'Workers at Southeast Asia garment factory supporting apparel production',
      },
      {
        src: '/assets/about/factory-people/factory-people-03.jpg',
        alt: 'Cambodia apparel factory team handling daily garment production',
      },
      {
        src: '/assets/about/factory-people/factory-people-04.jpg',
        alt: 'Garment workers in Cambodia factory production team',
      },
      {
        src: '/assets/about/factory-people/factory-people-07.jpg',
        alt: 'Factory team at TIMYOO Apparel Cambodia production site',
      },
      {
        src: '/assets/about/factory-people/factory-people-08.jpg',
        alt: 'Southeast Asia apparel manufacturing team at work',
      },
    ],
  },
  {
    eyebrow: 'Facilities',
    title: 'Factory spaces built for stable apparel output',
    summary:
      'Facility areas support fabric handling, sewing line organization, storage, packing, and repeat shipment preparation for global apparel buyers.',
    images: [
      {
        src: '/assets/about/facility/facility-09.jpg',
        alt: 'Southeast Asia garment factory production facility in Cambodia',
      },
      {
        src: '/assets/about/facility/facility-02.jpg',
        alt: 'Cambodia garment factory facility for apparel manufacturing',
      },
      {
        src: '/assets/about/facility/facility-08.jpg',
        alt: 'Apparel factory facility supporting repeat garment production',
      },
      {
        src: '/assets/about/facility/facility-06.jpg',
        alt: 'Factory production area for garment manufacturing in Southeast Asia',
      },
      {
        src: '/assets/about/facility/facility-05.jpg',
        alt: 'TIMYOO Apparel facility area for apparel sourcing programs',
      },
      {
        src: '/assets/about/facility/facility-11.jpg',
        alt: 'Cambodia apparel manufacturing facility for global buyers',
      },
    ],
  },
  {
    eyebrow: 'Daily Operations',
    title: 'Real factory visibility for sourcing teams',
    summary:
      'Buyers looking for a reliable Southeast Asia garment factory can review real production environments before discussing samples, capacity, and repeat orders.',
    images: [
      {
        src: '/assets/about/factory-live/factory-live-01.jpg',
        alt: 'Daily operations at Cambodia garment factory',
      },
      {
        src: '/assets/about/factory-live/factory-live-02.jpg',
        alt: 'Factory live scene at Southeast Asia apparel manufacturer',
      },
      {
        src: '/assets/about/factory-live/factory-live-03.jpg',
        alt: 'TIMYOO Apparel Cambodia factory daily work environment',
      },
    ],
  },
];

const productLinks = siteData.productsSection.items.map((item) => ({
  category: item.category,
  label: item.name,
  href: item.href ?? '/#products',
}));
const { facilities } = siteData.aboutSection;
const { value, whoWeWorkWith, cta } = siteData.homeAboutSection;

const structuredData = [
  buildOrganizationJsonLd(),
  {
    '@context': 'https://schema.org',
    '@type': 'AboutPage',
    '@id': `${absoluteUrl(canonicalPath)}#webpage`,
    url: absoluteUrl(canonicalPath),
    name: pageTitle,
    description: pageDescription,
    primaryImageOfPage: absoluteUrl(ogImage),
    isPartOf: {
      '@id': `${absoluteUrl('/')}#website`,
    },
    about: {
      '@id': `${absoluteUrl('/')}#organization`,
    },
    keywords: [
      'Southeast Asia garment factory',
      'Southeast Asia apparel manufacturer',
      'Cambodia apparel manufacturer',
      'Cambodia garment factory',
      'apparel sourcing Cambodia',
      'repeat garment production',
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    '@id': `${absoluteUrl(canonicalPath)}#breadcrumb`,
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: absoluteUrl('/'),
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Southeast Asia Garment Factory',
        item: absoluteUrl(canonicalPath),
      },
    ],
  },
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath={canonicalPath}
  ogImage={ogImage}
  structuredData={structuredData}
>
  <article id="southeast-asia-garment-factory-page" class="bg-white text-slate-950">
    <section class="relative overflow-hidden bg-slate-950 pb-14 pt-36 text-white md:pb-20 md:pt-44">
      <div class="absolute inset-0">
        <img src="/assets/about/facility/facility-09.jpg" alt="" class="h-full w-full object-cover opacity-35" loading="eager" />
        <div class="absolute inset-0 bg-slate-950/55"></div>
      </div>

      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <nav aria-label="Breadcrumb" class="mb-8 text-xs font-semibold uppercase tracking-[0.24em] text-slate-300">
          <ol class="flex flex-wrap items-center gap-2">
            <li>
              <a href="/" class="clickable-cursor transition-colors hover:text-white">Home</a>
            </li>
            <li aria-hidden="true" class="text-slate-500">/</li>
            <li aria-current="page" class="text-blue-200">Southeast Asia Garment Factory</li>
          </ol>
        </nav>

        <div class="max-w-4xl">
          <p class="mb-4 text-xs font-semibold uppercase tracking-[0.32em] text-blue-200">Factory Visibility</p>
          <h1 class="text-4xl font-bold leading-[1.05] tracking-tight md:text-6xl">Southeast Asia Garment Factory</h1>
          <p class="mt-6 max-w-2xl text-base leading-8 text-slate-200 md:text-lg">
            TIMYOO Apparel gives global buyers a Cambodia-based apparel manufacturing base inside Southeast Asia, with real factory visibility, stable capacity, and support for repeat garment production.
          </p>
        </div>

        <div class="mt-10 grid max-w-5xl gap-3 sm:grid-cols-2 lg:grid-cols-4">
          {proofPoints.map((point) => (
            <div class="border border-white/15 bg-white/10 px-5 py-4 backdrop-blur-sm">
              <div class="text-2xl font-bold tracking-tight">{point.value}</div>
              <div class="mt-1 text-xs font-semibold uppercase tracking-[0.2em] text-slate-300">{point.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-white py-14 md:py-20">
      <div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-12 lg:px-8">
        <div class="lg:col-span-4">
          <p class="text-xs font-semibold uppercase tracking-[0.28em] text-blue-700">Why this matters</p>
          <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-950 md:text-4xl">A broader sourcing base, with Cambodia factory proof.</h2>
        </div>
        <div class="space-y-5 text-base leading-8 text-slate-600 lg:col-span-8">
          <p>
            Buyers often search for a Southeast Asia garment factory before narrowing down to a specific country. Our production base is in Cambodia, giving sourcing teams a practical option for apparel programs that need stable capacity, cost control, and direct factory communication.
          </p>
          <p>
            The photos below show the factory spaces, people, and daily operating environment behind TIMYOO Apparel. They are meant to help buyers evaluate us before moving into product samples, compliance review, and repeat production planning.
          </p>
        </div>
      </div>
    </section>

    <section id="factory-profile" class="overflow-hidden bg-gray-50 py-14 md:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="reveal mb-12 text-center">
          <p class="text-xs font-semibold uppercase tracking-[0.28em] text-blue-700">Factory Profile</p>
          <h2 class="mt-3 text-3xl font-bold tracking-tight text-gray-950 md:text-4xl">A Manufacturing Partner Buyers Can Rely On</h2>
          <p class="mx-auto mt-4 max-w-3xl text-base leading-7 text-gray-600">
            This is the original About Us story behind the photo gallery: our factory timeline, production capacity, and the buyer problems we are built to solve.
          </p>
        </div>

        <div id="factory-profile-timeline" class="relative">
          <div class="absolute left-1/2 hidden h-full w-px -translate-x-1/2 bg-blue-200 md:block"></div>
          <div class="space-y-6 md:space-y-12">
            {factoryTimelineEvents.map((event, index) => {
              const isEven = index % 2 === 0;
              return (
                <div
                  id={toDomId('factory-profile-timeline-event', index + 1, event.year)}
                  class="reveal"
                  style={`--reveal-x: ${isEven ? '50px' : '-50px'}; --reveal-y: 0; --reveal-delay: ${index * 100}ms`}
                >
                  <div class={`flex flex-col items-center md:flex-row ${isEven ? 'md:flex-row-reverse' : ''}`}>
                    <div class="w-full flex-1 p-2 md:w-1/2 md:p-6">
                      <div class={`border-l-4 border-blue-500 bg-white p-5 shadow-md md:p-6 ${isEven ? 'text-left' : 'md:text-right'}`}>
                        <span class="block text-xl font-bold text-blue-600">{event.year}</span>
                        <h3 class="mt-2 text-xl font-bold text-gray-950">{event.title}</h3>
                        <p class="mt-2 text-sm leading-6 text-gray-600 md:text-base">{event.description}</p>
                      </div>
                    </div>

                    <div class="relative z-10 my-4 hidden h-8 w-8 items-center justify-center rounded-full border-4 border-white bg-blue-500 shadow-lg md:flex">
                      <div class="h-2 w-2 rounded-full bg-white"></div>
                    </div>

                    <div class="hidden w-full flex-1 p-6 md:block md:w-1/2"></div>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      </div>
    </section>

    <section id="factory-photo-gallery" class="bg-stone-50 pb-16 pt-6 md:pb-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="divide-y divide-stone-200">
          {gallerySections.map((section, sectionIndex) => (
            <section class="grid gap-8 py-12 lg:grid-cols-12 lg:items-start lg:gap-10">
              <div class={`lg:col-span-4 ${sectionIndex % 2 === 1 ? 'lg:order-2' : ''}`}>
                <p class="text-xs font-semibold uppercase tracking-[0.28em] text-blue-700">{section.eyebrow}</p>
                <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-950">{section.title}</h2>
                <p class="mt-4 text-base leading-7 text-slate-600">{section.summary}</p>
              </div>

              <div class={`lg:col-span-8 ${sectionIndex % 2 === 1 ? 'lg:order-1' : ''}`}>
                <div class="grid gap-3 sm:grid-cols-6">
                  {section.images.map((image, imageIndex) => (
                    <figure
                      id={toDomId('southeast-asia-factory-image', section.eyebrow, imageIndex + 1)}
                      class={`group overflow-hidden bg-white shadow-sm ${
                        imageIndex === 0 ? 'sm:col-span-4 sm:row-span-2' : 'sm:col-span-2'
                      }`}
                    >
                      <img
                        src={image.src}
                        alt={image.alt}
                        loading={sectionIndex === 0 && imageIndex === 0 ? 'eager' : 'lazy'}
                        decoding="async"
                        class={`h-full w-full object-cover transition duration-500 group-hover:scale-105 ${
                          imageIndex === 0 ? 'aspect-[16/11]' : 'aspect-[4/3]'
                        }`}
                      />
                    </figure>
                  ))}
                </div>
              </div>
            </section>
          ))}
        </div>
      </div>
    </section>

    <section id="factory-capacity" class="bg-white py-14 md:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="reveal mb-12 text-center">
          <p class="text-xs font-semibold uppercase tracking-[0.28em] text-blue-700">Capacity</p>
          <h2 class="text-3xl font-bold text-gray-950 md:text-4xl">{facilities.title}</h2>
          <p class="mx-auto mt-4 max-w-3xl text-lg leading-8 text-gray-600">{facilities.description}</p>
        </div>

        <div class="mx-auto grid max-w-5xl grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
          {facilities.items.map((item, index) => (
            <div
              id={toDomId('factory-capacity-item', index + 1, item.name)}
              class="reveal h-full"
              style={`--reveal-delay: ${index * 100}ms`}
            >
              <div class="flex h-full flex-col items-center justify-center border border-gray-100 bg-gray-50 p-6 text-center transition-shadow hover:shadow-md">
                <Icon name={item.icon} id={toDomId('factory-capacity-icon', item.name)} class="mb-4 h-8 w-8 text-blue-600" />
                <p class="text-lg font-medium text-gray-950">{item.name}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="factory-buyer-fit" class="bg-gray-50 py-14 md:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mb-14 grid gap-10 lg:grid-cols-2 lg:items-start">
          <div>
            <div class="reveal mb-8">
              <p class="text-xs font-semibold uppercase tracking-[0.28em] text-blue-700">Buyer Value</p>
              <h2 class="mt-3 text-3xl font-bold text-gray-950">{value.title}</h2>
            </div>
            <div class="grid gap-6">
              {value.items.map((item, index) => (
                <div class="reveal h-full" style={`--reveal-delay: ${index * 100}ms`}>
                  <div class="flex h-full items-center gap-4 border border-gray-100 bg-white p-6 transition-shadow hover:shadow-md">
                    <div class="bg-blue-100 p-3">
                      <Icon name={item.icon} id={toDomId('factory-value-icon', item.text)} class="h-6 w-6 text-blue-600" />
                    </div>
                    <h3 class="text-lg font-bold text-gray-950">{item.text}</h3>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div>
            <div class="reveal mb-8">
              <p class="text-xs font-semibold uppercase tracking-[0.28em] text-blue-700">Best Fit</p>
              <h2 class="mt-3 text-3xl font-bold text-gray-950">{whoWeWorkWith.title}</h2>
            </div>
            <div class="grid gap-6 sm:grid-cols-3 lg:grid-cols-1">
              {whoWeWorkWith.items.map((item, index) => (
                <div class="reveal h-full" style={`--reveal-delay: ${index * 100}ms`}>
                  <div class="flex h-full flex-col items-center justify-center border border-gray-100 bg-white p-6 text-center transition-shadow hover:shadow-md">
                    <Icon name={item.icon} id={toDomId('factory-fit-icon', item.text)} class="mb-4 h-8 w-8 text-blue-600" />
                    <p class="text-lg font-medium text-gray-950">{item.text}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="reveal mx-auto max-w-4xl text-center">
          <h2 class="text-3xl font-bold leading-tight text-gray-950">{cta.title}</h2>
          <p class="mx-auto mt-5 max-w-2xl text-lg leading-8 text-gray-600">{cta.description}</p>
          <a
            href={`mailto:${cta.email}`}
            class="clickable-cursor mt-9 inline-flex items-center gap-3 rounded-full bg-blue-600 px-6 py-3 text-base font-bold text-white transition-all hover:-translate-y-1 hover:bg-blue-700 hover:shadow-lg md:px-8 md:py-4 md:text-lg"
          >
            <Icon name="mail" id="factory-buyer-fit-cta-icon" class="h-5 w-5" />
            {cta.buttonLabel}
            <Icon name="arrowRight" id="factory-buyer-fit-cta-arrow" class="h-5 w-5 transition-transform group-hover:translate-x-1" />
          </a>
        </div>
      </div>
    </section>

    <section class="bg-white py-16 md:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-8 lg:grid-cols-12 lg:items-end">
          <div class="lg:col-span-7">
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-blue-700">Product programs</p>
            <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-950 md:text-4xl">Explore the apparel categories we produce.</h2>
            <p class="mt-4 max-w-2xl text-base leading-7 text-slate-600">
              Our Southeast Asia garment factory setup supports commercial workwear, hospitality uniforms, aprons, chef wear, and casualwear programs for repeat buyers.
            </p>
          </div>

          <div class="flex flex-wrap gap-3 lg:col-span-5 lg:justify-end">
            {productLinks.map((product) => (
              <a
                href={product.href}
                class="clickable-cursor inline-flex items-center gap-2 rounded-full border border-slate-300 px-4 py-2 text-xs font-bold uppercase tracking-[0.18em] text-slate-700 transition-colors hover:border-blue-700 hover:text-blue-700"
              >
                {product.category}
                <Icon name="arrowRight" id={toDomId('southeast-asia-factory-product-link-icon', product.category)} class="h-4 w-4" />
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  </article>
</BaseLayout>
