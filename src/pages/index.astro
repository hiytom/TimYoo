---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/astro/Hero.astro';
import Products from '../components/astro/Products.astro';
import CaseStudies from '../components/astro/CaseStudies.astro';
import AboutSections from '../components/astro/AboutSections.astro';
import { buildOrganizationJsonLd, buildWebsiteJsonLd } from '../utils/structuredData';

const structuredData = [buildOrganizationJsonLd(), buildWebsiteJsonLd()];
---

<BaseLayout
  title="Cambodia Apparel Manufacturer | TIMYOO Apparel"
  description="Cambodia-based apparel manufacturer serving global brands with chef wear, aprons, casualwear, repeat garment production, and Southeast Asia sourcing support."
  canonicalPath="/"
  ogImage="/assets/hero-factory-background.jpg"
  structuredData={structuredData}
>
  <Hero />
  <Products />
  <CaseStudies />
  <AboutSections />
</BaseLayout>
