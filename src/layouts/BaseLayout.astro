---
import '../index.css';
import logoUrl from '../assets/logo.svg?url';
import { siteData } from '../data/siteData';
import { toDomId } from '../utils/domId';
import Icon from '../components/astro/Icon.astro';

type Props = {
  title: string;
  description: string;
  canonicalPath?: string;
  ogImage?: string;
  robots?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
};

const {
  title,
  description,
  canonicalPath = '/',
  ogImage = '/assets/hero-factory-background.jpg',
  robots = 'index, follow',
  structuredData,
} = Astro.props;
const siteUrl = Astro.site ?? 'https://www.timyooapparel.com';
const canonicalUrl = new URL(canonicalPath, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();
const structuredDataItems = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];
const serializeJsonLd = (data: Record<string, unknown>) => JSON.stringify(data).replace(/</g, '\\u003c');
const { footer, navItems } = siteData;
const address = footer.contact.addressLines.join(' ');
const footerLinks = footer.quickLinks.map((link) => ({
  ...link,
  path: link.path === '#' ? '/' : link.path.startsWith('#') ? `/${link.path}` : link.path,
}));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <meta name="robots" content={robots} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    {structuredDataItems.map((item) => (
      <script type="application/ld+json" set:html={serializeJsonLd(item)} />
    ))}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <nav id="site-navbar" class="fixed w-full z-50 bg-transparent">
      <div id="navbar-container" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div id="navbar-layout" class="flex justify-between items-center h-28">
          <div id="navbar-logo-wrap" class="flex-shrink-0 flex items-center">
            <a id="navbar-home-link" href="/" class="clickable-cursor flex cursor-pointer items-center">
              <img id="navbar-logo-image" class="h-[1rem] w-auto cursor-pointer brightness-0 invert" src={logoUrl} alt="Company Logo" />
            </a>
          </div>

          <div id="navbar-desktop-links" class="hidden md:flex items-center space-x-8">
            {navItems.map((item) => (
              <a
                id={toDomId('navbar-link', item.name)}
                href={item.path}
                class="clickable-cursor cursor-pointer rounded-md px-3 py-2 text-sm font-medium text-white transition-colors hover:text-blue-400"
              >
                {item.name}
              </a>
            ))}
          </div>

          <div id="navbar-mobile-toggle-wrap" class="md:hidden flex items-center">
            <button id="navbar-mobile-toggle" class="clickable-cursor inline-flex cursor-pointer items-center justify-center rounded-md p-2 text-white hover:text-blue-400 focus:outline-none" aria-label="Toggle menu" aria-expanded="false">
              <Icon name="menu" id="navbar-mobile-toggle-menu-icon" class="menu-icon block" />
              <Icon name="x" id="navbar-mobile-toggle-x-icon" class="x-icon hidden" />
            </button>
          </div>
        </div>
      </div>

      <div id="navbar-mobile-menu" class="hidden md:hidden bg-gray-900/95 backdrop-blur-sm">
        <div id="navbar-mobile-links" class="px-2 pt-2 pb-3 space-y-1 sm:px-3">
          {navItems.map((item) => (
            <a
              id={toDomId('navbar-mobile-link', item.name)}
              href={item.path}
              class="clickable-cursor block cursor-pointer rounded-md px-3 py-2 text-base font-medium text-white hover:text-blue-400"
            >
              {item.name}
            </a>
          ))}
        </div>
      </div>
    </nav>

    <main id="app-main">
      <slot />
    </main>

    <footer class="bg-gray-900 text-white pt-16 pb-8" id="site-footer">
      <div id="footer-container" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div id="footer-grid" class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
          <div id="footer-company">
            <div id="footer-logo-wrap" class="mb-6 flex h-[1.75rem] items-center">
              <img id="footer-logo-image" src={logoUrl} alt="Logo" class="h-[0.875rem] w-auto brightness-0 invert" />
            </div>
            <p id="footer-summary" class="text-gray-400 mb-6">{footer.summary}</p>
          </div>

          <div id="footer-links-section">
            <h3 id="footer-links-title" class="text-lg font-semibold mb-6">Quick Links</h3>
            <ul id="footer-links-list" class="space-y-4">
              {footerLinks.map((link) => (
                <li id={toDomId('footer-link-item', link.name)}>
                  <a id={toDomId('footer-link', link.name)} href={link.path} class="text-gray-400 hover:text-white transition-colors">
                    {link.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <div id="footer-contact">
            <h3 id="footer-contact-title" class="text-lg font-semibold mb-6">Contact Us</h3>
            <ul id="footer-contact-list" class="space-y-4">
              <li id="footer-contact-address-item" class="flex items-start">
                <Icon name="mapPin" id="footer-contact-address-icon" class="w-5 h-5 shrink-0 text-blue-500 mr-3 mt-1" />
                <a id="footer-contact-address" href={footer.contact.mapUrl} target="_blank" rel="noreferrer" class="text-gray-400 hover:text-white transition-colors">
                  {address}
                </a>
              </li>
              <li id="footer-contact-email-item" class="flex items-center">
                <Icon name="mail" id="footer-contact-email-icon" class="w-5 h-5 shrink-0 text-blue-500 mr-3" />
                <a id="footer-contact-email" href={`mailto:${footer.contact.email}`} class="text-gray-400 hover:text-white transition-colors">
                  {footer.contact.email}
                </a>
              </li>
              <li id="footer-contact-phone-item" class="flex items-center">
                <Icon name="linkedin" id="footer-contact-phone-icon" class="w-5 h-5 shrink-0 text-[#0A66C2] mr-3" />
                <a id="footer-contact-phone" href="https://www.linkedin.com/in/hui-wang-2528a7b4" target="_blank" rel="noreferrer" class="text-gray-400 hover:text-white transition-colors">
                  LinkedIn
                </a>
              </li>
            </ul>
          </div>
        </div>

        <div id="footer-copyright-wrap" class="border-t border-gray-800 pt-8 text-center text-gray-500 text-sm">
          <p id="footer-copyright">&copy; {new Date().getFullYear()} {footer.companyName}. All rights reserved.</p>
        </div>
      </div>
    </footer>

    <button
      id="back-to-top-button"
      class="fixed bottom-8 right-8 p-3 bg-blue-600 text-white rounded-full shadow-lg hover:bg-blue-700 transition-all z-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 opacity-0 scale-50 pointer-events-none"
      aria-label="Back to top"
    >
      <Icon name="arrowUp" id="back-to-top-icon" />
    </button>

    <script>
      const navbar = document.getElementById('site-navbar');
      const mobileToggle = document.getElementById('navbar-mobile-toggle');
      const mobileMenu = document.getElementById('navbar-mobile-menu');
      const menuIcon = document.getElementById('navbar-mobile-toggle-menu-icon');
      const xIcon = document.getElementById('navbar-mobile-toggle-x-icon');
      const backToTop = document.getElementById('back-to-top-button');
      const NAVBAR_OFFSET = 112;
      let previousScrollY = window.scrollY;

      const scrollToSection = (sectionId, behavior = 'smooth') => {
        const element = document.getElementById(sectionId);

        if (!element) {
          return false;
        }

        const top = element.getBoundingClientRect().top + window.scrollY - NAVBAR_OFFSET;
        window.scrollTo({ top: Math.max(top, 0), behavior });
        return true;
      };

      const closeMobileMenu = () => {
        mobileMenu?.classList.add('hidden');
        menuIcon?.classList.remove('hidden');
        xIcon?.classList.add('hidden');
        mobileToggle?.setAttribute('aria-expanded', 'false');
      };

      const openMobileMenu = () => {
        mobileMenu?.classList.remove('hidden');
        menuIcon?.classList.add('hidden');
        xIcon?.classList.remove('hidden');
        mobileToggle?.setAttribute('aria-expanded', 'true');
      };

      mobileToggle?.addEventListener('click', () => {
        const isOpen = !mobileMenu?.classList.contains('hidden');
        isOpen ? closeMobileMenu() : openMobileMenu();
      });

      document.querySelectorAll('#site-navbar a[href]').forEach((link) => {
        link.addEventListener('click', (event) => {
          closeMobileMenu();

          const href = link.getAttribute('href');
          if (!href) {
            return;
          }

          const targetUrl = new URL(href, window.location.href);
          const isSamePageHash = targetUrl.pathname === window.location.pathname && targetUrl.hash;

          if (!isSamePageHash) {
            return;
          }

          const targetId = targetUrl.hash.slice(1);
          if (scrollToSection(targetId)) {
            event.preventDefault();
            window.history.pushState(null, '', targetUrl.hash);
          }
        });
      });

      const updateNavbar = () => {
        const latest = window.scrollY;
        const scrolled = latest > 50;

        navbar?.classList.toggle('bg-transparent', !scrolled);
        navbar?.classList.toggle('bg-gray-900/90', scrolled);
        navbar?.classList.toggle('backdrop-blur-sm', scrolled);
        navbar?.classList.toggle('shadow-md', scrolled);
        navbar?.classList.toggle('navbar-hidden', latest > previousScrollY && latest > 150);
        backToTop?.classList.toggle('opacity-0', latest <= 300);
        backToTop?.classList.toggle('scale-50', latest <= 300);
        backToTop?.classList.toggle('pointer-events-none', latest <= 300);
        previousScrollY = latest;
      };

      updateNavbar();
      window.addEventListener('pageshow', updateNavbar);
      window.addEventListener('scroll', updateNavbar, { passive: true });

      backToTop?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });

      if (window.location.hash) {
        window.setTimeout(() => {
          scrollToSection(window.location.hash.slice(1), 'smooth');
        }, 0);
      }

      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            revealObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -100px 0px' });

      document.querySelectorAll('.reveal').forEach((element) => revealObserver.observe(element));
    </script>
  </body>
</html>
